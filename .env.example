# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Admin Control Portal password. Leave empty here and set a secure value in your environment / .env.local file.
ADMIN_PASSWORD=""

# Required in production for durable inquiry storage and admin sessions.
# Use the pooled/connection string from Neon, Supabase, or a Vercel Marketplace Postgres provider.
DATABASE_URL=""
# Most managed Postgres providers require SSL. Set DATABASE_SSL="false" only for trusted local databases.
DATABASE_SSL="true"
DATABASE_SSL_REJECT_UNAUTHORIZED="true"

# Inquiry and SMTP Configurations
# Any inquiries submitted through the contact form will be forwarded to this address.
INQUIRY_RECEIVER_EMAIL=""

# Set up SMTP credentials to activate automatic email forwarding to your inbox.
# Gmail example (requires a Google App Password — not your normal login password):
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_PORT="587"
#   SMTP_USER="your@gmail.com"
#   SMTP_PASS="your-16-char-app-password"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Set up Resend credentials as an alternative to SMTP for reliable email delivery.
#   RESEND_API_KEY="re_123456789"
#   RESEND_FROM_EMAIL="onboarding@resend.dev" # Change to your verified domain sender once verified (e.g. hello@yourdomain.com)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
